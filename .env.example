# =============================================================================
# CRONOMETER ETL PIPELINE ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and update the values according to your personal data

# =============================================================================
# USER PHYSICAL PARAMETERS
# =============================================================================
# Your height in centimeters (used for BMI calculations)
USER_HEIGHT_CM=175

# Your current weight in kilograms (optional, for reference)
CURRENT_WEIGHT_KG=75

# =============================================================================
# HEALTH & FITNESS GOALS
# =============================================================================
# Target weight you want to achieve (kg)
TARGET_WEIGHT_KG=70

# Daily calorie target
TARGET_CALORIES=2000

# Daily protein goal in grams
PROTEIN_GOAL_G=100

# Daily fiber goal in grams
FIBER_GOAL_G=25

# Calorie tolerance percentage (0.1 = 10% tolerance for "on track" calculations)
CALORIE_TOLERANCE_PCT=0.1

# =============================================================================
# CRONOMETER CREDENTIALS
# =============================================================================
# Your Cronometer login credentials
CRONOMETER_USERNAME=your_username_here
CRONOMETER_PASSWORD=your_password_here

# =============================================================================
# OPTIONAL GARMIN CONNECT CONFIGURATION
# =============================================================================
# Enable Garmin ingestion in the DAG when true. Keep this true if you want
# pre-seeded Garmin CSV artifacts to be merged into processed_data.csv.
GARMIN_ENABLED=false

# Garmin Connect credentials used only for the one-time token bootstrap flow
GARMIN_EMAIL=your_garmin_email_here
GARMIN_PASSWORD=your_garmin_password_here

# Optional historical sync start date for the first API backfill when no
# Garmin history has already been pre-seeded into the mounted CSV store
GARMIN_HISTORICAL_START_DATE=2024-05-03

# Number of days to re-fetch during incremental syncs to capture late Garmin updates
GARMIN_SYNC_OVERLAP_DAYS=2

# Force a full Garmin history rebuild on the next run when true; set this back
# to false immediately after the rebuild completes
GARMIN_FORCE_FULL_REFRESH=false

# Legacy fallback window used only when no historical start date is configured
GARMIN_LOOKBACK_DAYS=30

# Persistent token directory inside the Airflow containers used by scheduled
# Garmin syncs after the manual bootstrap has completed
GARMINTOKENS=/opt/airflow/config/garmin_tokens

# =============================================================================
# AWS S3 CONFIGURATION
# =============================================================================
# AWS credentials for S3 upload
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# S3 bucket name for storing reports
S3_BUCKET_NAME=your-cronometer-bucket

# Toggle S3 upload (set to true to enable, false to skip)
UPLOAD_TO_S3=false

# =============================================================================
# VISUALIZATION PREFERENCES
# =============================================================================
# Number of days for rolling averages (comma-separated)
ROLLING_WINDOW_DAYS=7,30

# Analysis period in days (for recent data analysis)
ANALYSIS_PERIOD_DAYS=90

# Weight stability threshold (kg) - daily changes below this are considered "stable"
WEIGHT_STABILITY_THRESHOLD=0.5

# =============================================================================
# AIRFLOW CONFIGURATION
# =============================================================================
# Airflow UID (usually 50000 in Docker)
AIRFLOW_UID=50000

# Airflow project directory
AIRFLOW_PROJ_DIR=.

# =============================================================================
# OPTIONAL ADVANCED SETTINGS
# =============================================================================
# Macro ratio targets (percentages, should sum to 100)
TARGET_PROTEIN_PCT=25
TARGET_CARBS_PCT=45
TARGET_FAT_PCT=30

# Minimum data points required for trend analysis
MIN_DATA_POINTS_TREND=7

# Prediction horizon in days
PREDICTION_HORIZON_DAYS=30
